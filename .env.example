APP_HOST=http://localhost
API_HOST=http://localhost
IMG_HOST=http://localhost
IMAGE_PUBLIC_BASE=http://localhost/uploads

C_EX_HOST=chrome-extension://your-extension-id
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_UPLOAD_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,gif
FILE_UPLOAD_DIR=/data/uploads/images

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
NAVER_CLIENT_ID=replace-me
NAVER_CLIENT_SECRET=replace-me
KAKAO_CLIENT_ID=replace-me
